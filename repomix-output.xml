}

/* =========================================
   EDITOR HUB
   ========================================= */

.editor-toolbar {
    display: flex;
    gap: 10px;
    width: 100%;
    max-width: 600px;
    margin-bottom: 10px;
}

.level-list-editor {
    width: 100%;
    max-width: 700px;
